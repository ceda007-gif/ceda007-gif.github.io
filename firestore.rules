rules_version = '2';

// Reglas de seguridad para el motor de reservaciones.
// Cópialas en Firebase Console > Firestore Database > Reglas, y publica.
//
// Lógica:
// - Cualquier visitante puede CREAR una reservación (con validación básica
//   de los campos requeridos), para que el flujo público de reservas funcione.
// - Solo un usuario autenticado (el administrador que creaste en
//   Authentication) puede LEER, ACTUALIZAR o BORRAR reservaciones, para que
//   nadie pueda ver o modificar los datos de otros huéspedes.
service cloud.firestore {
  match /databases/{database}/documents {
    match /reservations/{reservationId} {
      allow read: if request.auth != null;

      allow create: if request.resource.data.keys().hasAll([
          'roomId', 'roomTitle', 'checkIn', 'checkOut', 'nights',
          'guests', 'totalPrice', 'currency', 'guestName', 'guestEmail',
          'guestPhone', 'status'
        ])
        && request.resource.data.status == 'confirmed'
        && request.resource.data.checkIn is string
        && request.resource.data.checkOut is string
        && request.resource.data.checkOut > request.resource.data.checkIn
        && request.resource.data.guestName is string
        && request.resource.data.guestEmail is string
        && request.resource.data.totalPrice is number
        && request.resource.data.totalPrice > 0;

      allow update, delete: if request.auth != null;
    }
  }
}
